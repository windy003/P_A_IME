<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 读写外部存储根目录的 pinyin_simp.dict.yaml。Android 11+ 用 MANAGE_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <!-- 与 Cloudflare Worker 同步 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light">

        <!-- 设置/引导页:启用输入法、授予文件权限、查看词库状态 -->
        <activity
            android:name=".SetupActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 文字编辑页:新建文件夹 / 新建常用语(输入法窗口内无法打字,跳到这里编辑) -->
        <activity
            android:name=".PhraseEditActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <!-- 同步页:登录 Worker、比较两端差异、执行增量双向同步 -->
        <activity
            android:name=".SyncActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:windowSoftInputMode="stateHidden|adjustResize" />

        <!-- 输入法服务 -->
        <service
            android:name=".PinyinImeService"
            android:exported="true"
            android:label="@string/ime_name"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>
    </application>
</manifest>
